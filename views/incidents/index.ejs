<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">Incident Management</h2>
            <p class="text-secondary mb-0">
                View and manage all reported incidents.
            </p>
        </div>

        <a href="/incidents/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>
            Report Incident
        </a>

    </div>

    <% if (incidents.length === 0) { %>

        <div class="alert alert-info">
            No incidents have been reported yet.
        </div>

    <% } else { %>

        <div class="row">

            <% incidents.forEach(incident => { %>

                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card shadow-sm h-100">

                        <% if (incident.image_data) { %>

                            <img
                                src="/incidents/<%= incident.id %>/image"
                                class="incident-card-image"
                                alt="<%= incident.title %> image">

                        <% } else { %>

                            <div class="incident-card-image incident-card-image-empty">
                                No image
                            </div>

                        <% } %>

                        <div class="card-body">

                            <h5><%= incident.title %></h5>

                            <p class="text-muted">
                                <%= incident.description %>
                            </p>

                            <span class="badge bg-danger">
                                <%= incident.severity %>
                            </span>

                            <span class="badge bg-secondary">
                                <%= incident.category %>
                            </span>

                            <hr>

                            <p class="mb-1">
                                <strong>Location:</strong>
                                <%= incident.location %>
                            </p>

                            <p class="mb-1">
                                <strong>Status:</strong>
                                <%= incident.status %>
                            </p>

                            <p class="text-muted mb-3">
                                Reported by <%= incident.username %>
                            </p>

                            <a href="/incidents/<%= incident.id %>" class="btn btn-outline-primary btn-sm">
                                View Details
                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>
