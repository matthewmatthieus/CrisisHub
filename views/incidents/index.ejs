<div class="page-header">
    <div>
        <h1>Incidents</h1>
        <p>Manage incident reports that impact community safety and resources.</p>
    </div>

    <% if (isAdmin) { %>
        <div class="page-actions">
            <a class="btn btn-primary" href="/incidents/new">
                <i class="bi bi-plus-circle me-1"></i>
                New Incident
            </a>
        </div>
    <% } %>
</div>

<% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
<% } %>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="content-card">
    <div class="card-header">
        <h2>
            <i class="bi bi-exclamation-triangle-fill"></i>
            Incident Reports
        </h2>
        <span class="text-secondary"><%= incidents.length %> incidents</span>
    </div>

    <% if (incidents.length === 0) { %>
        <p class="empty-state">No incidents have been reported yet.</p>
    <% } else { %>
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Severity</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Owner</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% incidents.forEach((incident) => { %>
                        <tr>
                            <td><strong><%= incident.title %></strong></td>
                            <td><%= incident.category %></td>
                            <td><%= incident.severity %></td>
                            <td><%= incident.location %></td>
                            <td><span class="status-pill"><%= incident.status %></span></td>
                            <td><%= incident.owner_name || 'Unknown' %></td>
                            <td class="text-end">
                                <a class="btn btn-outline-light btn-sm" href="/incidents/<%= incident.id %>">
                                    Details
                                </a>
                                <% if (isAdmin) { %>
                                    <a class="btn btn-outline-light btn-sm" href="/incidents/<%= incident.id %>/edit">
                                        Edit
                                    </a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
