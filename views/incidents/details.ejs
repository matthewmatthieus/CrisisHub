<div class="container-fluid py-4">

    <a href="/incidents" class="btn btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left"></i>
        Back to Incidents
    </a>

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-start">

                <div>

                    <h2 class="fw-bold">
                        <%= incident.title %>
                    </h2>

                    <div class="mt-2">

                        <span class="badge bg-danger">
                            <%= incident.severity %>
                        </span>

                        <span class="badge bg-primary">
                            <%= incident.category %>
                        </span>

                        <% if (incident.status === 'Active') { %>

                            <span class="badge bg-warning text-dark">
                                Active
                            </span>

                        <% } else { %>

                            <span class="badge bg-success">
                                Resolved
                            </span>

                        <% } %>

                    </div>

                </div>

            </div>

            <hr>

            <h5>Description</h5>

            <p>
                <%= incident.description %>
            </p>

            <h5>Location</h5>

            <p>
                <i class="bi bi-geo-alt-fill text-danger"></i>
                <%= incident.location %>
            </p>

            <% if (incident.latitude && incident.longitude) { %>

                <p class="text-muted">

                    Latitude:
                    <%= incident.latitude %>

                    <br>

                    Longitude:
                    <%= incident.longitude %>

                </p>

            <% } %>

            <% if (incident.image_data) { %>

                <hr>

                <img
                    src="/incidents/<%= incident.id %>/image"
                    class="incident-detail-image"
                    alt="<%= incident.title %> image">

            <% } %>

            <hr>

            <p class="mb-1">

                <strong>Reported By:</strong>

                <%= incident.username %>

            </p>

            <p>

                <strong>Reported On:</strong>

                <%= new Date(incident.created_at).toLocaleString() %>

            </p>

            <div class="mt-4">

                <% if (isAdmin) { %>

                    <a
                        href="/incidents/<%= incident.id %>/edit"
                        class="btn btn-warning">

                        Edit

                    </a>

                    <form
                        action="/incidents/<%= incident.id %>/delete"
                        method="POST"
                        class="d-inline">

                        <button
                            type="submit"
                            class="btn btn-danger"
                            onclick="return confirm('Delete this incident?')">

                            Delete

                        </button>

                    </form>

                <% } else if (isOwner) { %>

                    <a
                        href="/incidents/<%= incident.id %>/edit"
                        class="btn btn-warning">

                        Edit

                    </a>

                <% } %>

            </div>

        </div>

    </div>

</div>
