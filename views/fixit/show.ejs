<div class="container-fluid py-4">

  <a href="/fixit" class="btn btn-outline-secondary mb-4">
    <i class="bi bi-arrow-left"></i>
    Back to FixIt Reports
  </a>

  <div class="card shadow-sm">
    <div class="card-body">

      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h2 class="fw-bold"><%= fixit.title %></h2>

          <div class="mt-2">
            <span class="badge bg-danger"><%= fixit.severity %></span>
            <span class="badge bg-primary"><%= fixit.category %></span>

            <% if (fixit.status === 'Active') { %>
              <span class="badge bg-warning text-dark">Active</span>
            <% } else { %>
              <span class="badge bg-success">Resolved</span>
            <% } %>
          </div>
        </div>
      </div>

      <hr>

      <h5>Description</h5>
      <p><%= fixit.description %></p>

      <h5>Location</h5>
      <p>
        <i class="bi bi-geo-alt-fill text-danger"></i>
        <%= fixit.location %>
      </p>

      <% if (fixit.latitude && fixit.longitude) { %>
        <p class="text-muted">
          Latitude: <%= fixit.latitude %><br>
          Longitude: <%= fixit.longitude %>
        </p>
      <% } %>

      <% if (fixit.photo_url) { %>
        <hr>
        <a href="<%= fixit.photo_url %>" target="_blank">
          <img src="<%= fixit.photo_url %>" 
               class="img-fluid rounded mt-2" 
               style="max-width:150px; height:auto;">
        </a>
      <% } %>

      <hr>

      <p class="mb-1"><strong>Reported By:</strong> <%= fixit.reported_by || "Anonymous" %></p>
      <p><strong>Reported On:</strong> <%= new Date(fixit.created_at).toLocaleString() %></p>

      <div class="mt-4">
        <a href="/fixit/<%= fixit.id %>/edit" class="btn btn-warning">Edit</a>
        <form action="/fixit/<%= fixit.id %>?_method=DELETE" method="POST" class="d-inline">
          <button class="btn btn-danger" onclick="return confirm('Delete this FixIt report?')">
            Delete
          </button>
        </form>
      </div>

    </div>
  </div>
</div>
