<div class="container-fluid py-4">

  <a href="/fixit" class="btn btn-outline-secondary mb-4">
    <i class="bi bi-arrow-left"></i>
    Back to FixIt Reports
  </a>

  <div class="card shadow-sm">
    <div class="card-body">

      <h2 class="fw-bold mb-4">Edit FixIt Report</h2>

      <form action="/fixit/<%= fixit.id %>?_method=PUT" method="POST" enctype="multipart/form-data">

        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input type="text" id="title" name="title" class="form-control" value="<%= fixit.title %>" required>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea id="description" name="description" class="form-control" rows="3" required><%= fixit.description %></textarea>
        </div>

        <div class="mb-3">
          <label for="category" class="form-label">Category</label>
          <input type="text" id="category" name="category" class="form-control" value="<%= fixit.category %>" required>
        </div>

        <div class="mb-3">
          <label for="severity" class="form-label">Severity</label>
          <select id="severity" name="severity" class="form-select" required>
            <option value="Low" <%= fixit.severity === 'Low' ? 'selected' : '' %>>Low</option>
            <option value="Medium" <%= fixit.severity === 'Medium' ? 'selected' : '' %>>Medium</option>
            <option value="High" <%= fixit.severity === 'High' ? 'selected' : '' %>>High</option>
            <option value="Critical" <%= fixit.severity === 'Critical' ? 'selected' : '' %>>Critical</option>
          </select>
        </div>

        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input type="text" id="location" name="location" class="form-control" value="<%= fixit.location %>" required>
        </div>

        <div class="mb-3">
          <label for="status" class="form-label">Status</label>
          <select id="status" name="status" class="form-select" required>
            <option value="Active" <%= fixit.status === 'Active' ? 'selected' : '' %>>Active</option>
            <option value="Resolved" <%= fixit.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
          </select>
        </div>

        <div class="mb-3">
          <label for="photo" class="form-label">Upload Photo</label>
          <input type="file" id="photo" name="photo" class="form-control">
          <% if (fixit.photo_url) { %>
            <p class="text-muted mt-2">Current photo:</p>
            <a href="<%= fixit.photo_url %>" target="_blank">
              <img src="<%= fixit.photo_url %>" 
                   alt="FixIt photo" 
                   class="img-fluid rounded mt-2" 
                   style="max-width:150px; height:auto;">
            </a>
          <% } %>
        </div>

        <button type="submit" class="btn btn-success">Save Changes</button>
        <a href="/fixit/<%= fixit.id %>" class="btn btn-secondary">Cancel</a>

      </form>

    </div>
  </div>
</div>
