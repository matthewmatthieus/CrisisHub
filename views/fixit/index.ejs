<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                FixIt Reports
            </h2>

            <p class="text-muted mb-0">
                Community issues reported by citizens who needs help.
            </p>
        </div>

        <a href="/fixit/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            New Report
        </a>

    </div>

    <% if (!reports || reports.length === 0) { %>

        <div class="card shadow-sm">

            <div class="card-body text-center py-5">

                <i class="bi bi-tools display-3 text-secondary"></i>

                <h4 class="mt-3">
                    No FixIt Reports
                </h4>

                <p class="text-muted">
                    Be the first to report a damaged public facility.
                </p>

                <a href="/fixit/create" class="btn btn-primary">
                    Create First Report
                </a>

            </div>

        </div>

    <% } else { %>

        <div class="row g-4">

            <% reports.forEach(report => { %>

                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card shadow-sm h-100">

                        <% if (report.image_data) { %>

                            <img
                                src="/fixit/<%= report.id %>/image"
                                class="incident-card-image"
                                alt="<%= report.title %> image">

                        <% } else { %>

                            <div class="incident-card-image incident-card-image-empty">
                                No image
                            </div>

                        <% } %>

                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-start">

                                <h5 class="fw-bold">
                                    <%= report.title %>
                                </h5>

                                <% if(report.status==="Open"){ %>

                                    <span class="badge bg-danger">
                                        Open
                                    </span>

                                <% }else if(report.status==="In Progress"){ %>

                                    <span class="badge bg-warning text-dark">
                                        In Progress
                                    </span>

                                <% }else{ %>

                                    <span class="badge bg-success">
                                        Resolved
                                    </span>

                                <% } %>

                            </div>

                            <p class="text-muted mb-2">

                                <i class="bi bi-tag-fill me-1"></i>

                                <%= report.category %>

                            </p>

                            <p>

                                <%= report.description.length > 150
                                    ? report.description.substring(0,150) + "..."
                                    : report.description %>

                            </p>

                            <hr>

                            <p class="mb-1">
                                <strong>Location:</strong>
                                <%= report.location %>
                            </p>

                            <p class="mb-1">
                                <strong>Status:</strong>
                                <%= report.status %>
                            </p>

                            <p class="text-muted mb-3">
                                Reported by <%= report.username %>
                            </p>

                            <p class="text-muted mb-3">
                                <i class="bi bi-people-fill me-1"></i>
                                <%= report.volunteerCount || 0 %> volunteers
                            </p>

                        </div>

                        <div class="card-footer">

                            <div class="d-flex gap-2">

                                <a
                                    href="/fixit/<%= report.id %>"
                                    class="btn btn-outline-primary flex-fill"
                                >
                                    View Details
                                </a>

                                <% if (report.status !== "Resolved") { %>

                                    <% if (report.userVolunteered) { %>

                                        <form action="/fixit/<%= report.id %>/withdraw" method="POST" class="flex-fill">

                                            <button
                                                type="submit"
                                                class="btn btn-outline-danger w-100"
                                            >
                                                <i class="bi bi-x-circle me-1"></i>
                                                Withdraw
                                            </button>

                                        </form>

                                    <% } else { %>

                                        <form action="/fixit/<%= report.id %>/volunteer" method="POST" class="flex-fill">

                                            <button
                                                type="submit"
                                                class="btn btn-success w-100"
                                            >
                                                <i class="bi bi-hand-thumbs-up me-1"></i>
                                                Volunteer
                                            </button>

                                        </form>

                                    <% } %>

                                <% } %>

                            </div>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>