<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-tools me-2"></i>
                FixIt Reports
            </h2>

            <p class="text-muted mb-0">
                Community infrastructure issues reported by citizens.
            </p>
        </div>

        <a href="/fixit/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            New Report
        </a>

    </div>

    <% if (!reports || reports.length === 0) { %>

        <div class="card shadow-sm">

            <div class="card-body text-center py-5">

                <i class="bi bi-tools display-3 text-secondary"></i>

                <h4 class="mt-3">
                    No FixIt Reports
                </h4>

                <p class="text-muted">
                    Be the first to report a damaged public facility.
                </p>

                <a href="/fixit/create" class="btn btn-primary">
                    Create First Report
                </a>

            </div>

        </div>

    <% } else { %>

        <div class="row g-4">

            <% reports.forEach(report => { %>

                <div class="col-lg-6">

                    <div class="card shadow-sm h-100">

                        <% if(report.image_data){ %>

                            <img
                                src="/fixit/<%= report.id %>/image"
                                class="card-img-top"
                                style="height:220px; object-fit:cover;"
                            >

                        <% } %>

                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-start">

                                <h5 class="fw-bold">
                                    <%= report.title %>
                                </h5>

                                <% if(report.status==="Open"){ %>

                                    <span class="badge bg-danger">
                                        Open
                                    </span>

                                <% }else if(report.status==="In Progress"){ %>

                                    <span class="badge bg-warning text-dark">
                                        In Progress
                                    </span>

                                <% }else{ %>

                                    <span class="badge bg-success">
                                        Resolved
                                    </span>

                                <% } %>

                            </div>

                            <p class="text-muted mb-2">

                                <i class="bi bi-tag-fill me-1"></i>

                                <%= report.category %>

                            </p>

                            <p>

                                <%= report.description.length > 150
                                    ? report.description.substring(0,150) + "..."
                                    : report.description %>

                            </p>

                            <hr>

                            <div class="small text-muted">

                                <div>

                                    <i class="bi bi-geo-alt"></i>

                                    <%= report.location %>

                                </div>

                                <div>

                                    <i class="bi bi-person"></i>

                                    <%= report.username %>

                                </div>

                                <div>

                                    <i class="bi bi-calendar"></i>

                                    <%= new Date(report.created_at).toLocaleDateString() %>

                                </div>

                            </div>

                        </div>

                        <div class="card-footer bg-white">

                            <a
                                href="/fixit/<%= report.id %>"
                                class="btn btn-outline-primary w-100"
                            >

                                View Details

                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>