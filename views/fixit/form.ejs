<div class="page-header">
    <div>
        <h1>Report New FixIt Issue</h1>
        <p>Report infrastructure and maintenance issues so they can be tracked and resolved.</p>
    </div>
</div>

<div class="content-card form-card">
    <form action="/api/fixit" method="POST" enctype="multipart/form-data">
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label" for="title">Title</label>
                <input class="form-control" id="title" name="title" type="text"
                       placeholder="e.g. Street lamp out along Clementi Ave 3" required>
            </div>

            <div class="col-md-6">
                <label class="form-label" for="description">Description</label>
                <textarea class="form-control" id="description" name="description" rows="4"
                          placeholder="Describe what you see – size, time, who is affected, dangers..." required></textarea>
            </div>

            <div class="col-md-6">
                <label class="form-label" for="category">Category</label>
                <select class="form-select" id="category" name="category" required>
                    <option value="" selected disabled>Select a category...</option>
                    <% ['Broken Lights', 'Road Damage', 'Drainage', 'Public Facilities', 'Infrastructure', 'Other'].forEach((category) => { %>
                        <option value="<%= category %>"><%= category %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label" for="location">Location</label>
                <input class="form-control" id="location" name="location" type="text"
                       placeholder="e.g. Bedok Interchange, Tampines Ave 3" required>
            </div>

            <div class="col-md-6">
                <label class="form-label" for="severity">Severity</label>
                <select class="form-select" id="severity" name="severity" required>
                    <% ['Low', 'Medium', 'High', 'Critical'].forEach((severity) => { %>
                        <option value="<%= severity %>" <%= severity === 'Medium' ? 'selected' : '' %>>
                            <%= severity %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="col-12">
                <label class="form-label" for="photo">Image</label>
                <input class="form-control" type="file" id="photo" name="photo"
                       accept=".png,.jpg,.jpeg,.gif,.webp">
                <div class="form-text">Upload a PNG, JPG, GIF, or WEBP image up to 2MB.</div>
            </div>
        </div>

        <div class="form-actions">
            <a class="btn btn-outline-light" href="/fixit">Cancel</a>
            <button class="btn btn-primary" type="submit">
                <i class="bi bi-check-circle me-1"></i>
                Submit FixIt Issue
            </button>
        </div>
    </form>
</div>
