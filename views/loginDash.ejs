<div class="container py-4">
    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h3 class="mb-1">Dashboard</h3>
                    <p class="text-muted mb-0">
                        Welcome back, <strong><%= user ? user.username : (currentUser ? currentUser.username : 'Member') %></strong>.
                        Your authenticated identity is available through <code>req.session.user</code> for integration with future modules.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Role</h6>
                    <p class="mb-0 fs-5 fw-semibold"><%= user ? user.role : (currentUser ? currentUser.role : '-') %></p>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Status</h6>
                    <p class="mb-0 fs-5 fw-semibold"><%= user ? user.status : '-' %></p>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Reputation</h6>
                    <p class="mb-0 fs-5 fw-semibold"><%= user ? user.reputation_score : '-' %></p>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5>Recent Activity</h5>
                    <% if (!activity || activity.length === 0) { %>
                        <div class="alert alert-secondary mb-0">No user activity yet.</div>
                    <% } else { %>
                        <ul class="list-group list-group-flush">
                            <% activity.forEach((item) => { %>
                                <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                    <span><%= item.activity %></span>
                                    <small class="text-muted"><%= new Date(item.created_at).toLocaleString() %></small>
                                </li>
                            <% }) %>
                        </ul>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>