<aside class="sidebar">

    <div class="sidebar-section">

        <div class="sidebar-title">
            Community
        </div>

        <a href="/" class="sidebar-link <%= currentPath === '/' ? 'active' : '' %>">

            <div class="sidebar-left">

                <i class="bi bi-grid-fill"></i>

                <span>All Reports</span>

            </div>

            <span class="sidebar-count"><%= sidebarCounts.allReports %></span>

        </a>

        <a href="/incidents" class="sidebar-link <%= currentPath.startsWith('/incidents') ? 'active' : '' %>">

            <div class="sidebar-left">

                <i class="bi bi-exclamation-triangle-fill text-warning"></i>

                <span>Incidents</span>

            </div>

            <span class="sidebar-count"><%= sidebarCounts.incidents %></span>

        </a>

        <a href="/helpRequests" class="sidebar-link <%= currentPath.startsWith('/helpRequests') ? 'active' : '' %>">

            <div class="sidebar-left">

                <i class="bi bi-life-preserver text-danger"></i>

                <span>Help Requests</span>

            </div>

            <span class="sidebar-count"><%= sidebarCounts.helpRequests %></span>

        </a>

        <a href="/resourceOffers" class="sidebar-link <%= currentPath.startsWith('/resourceOffers') ? 'active' : '' %>">

            <div class="sidebar-left">

                <i class="bi bi-box-seam-fill text-success"></i>

                <span>Resources</span>

            </div>

            <span class="sidebar-count"><%= sidebarCounts.resourceOffers %></span>

        </a>

        <a href="/verification" class="sidebar-link <%= currentPath.startsWith('/verification') ? 'active' : '' %>">

            <div class="sidebar-left">

                <i class="bi bi-patch-check-fill text-info"></i>

                <span>Verify Incidents</span>

            </div>

            <span class="sidebar-count"><%= sidebarCounts.verification %></span>

        </a>

    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">

        <div class="sidebar-title">
            ADMIN
        </div>


    </div>

    <% const counts = typeof sidebarCounts !== 'undefined' ? sidebarCounts : { allReports: 0, incidents: 0, helpRequests: 0, resourceOffers: 0, verification: 0 }; %>
    <span class="sidebar-count"><%= counts.allReports %></span>
    <span class="sidebar-count"><%= counts.incidents %></span>
    <span class="sidebar-count"><%= counts.helpRequests %></span>
    <span class="sidebar-count"><%= counts.resourceOffers %></span>
    <span class="sidebar-count"><%= counts.verification %></span>

</aside>
