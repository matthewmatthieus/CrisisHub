<aside class="sidebar">

    <div class="sidebar-section">

        <div class="sidebar-title">
            Community
        </div>

        <a href="/" class="sidebar-link <%= currentPath === '/' ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-grid-fill"></i>
                <span>All Reports</span>
            </div>
            <span class="sidebar-count"><%= sidebarCounts.allReports %></span>
        </a>

        <a href="/incidents" class="sidebar-link <%= currentPath.startsWith('/incidents') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-exclamation-triangle-fill text-warning"></i>
                <span>Incidents</span>
            </div>
            <span class="sidebar-count"><%= sidebarCounts.incidents %></span>
        </a>

        <a href="/helpRequests" class="sidebar-link <%= currentPath.startsWith('/helpRequests') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-life-preserver text-danger"></i>
                <span>Help Requests</span>
            </div>
            <span class="sidebar-count"><%= sidebarCounts.helpRequests %></span>
        </a>

        <a href="/resourceOffers" class="sidebar-link <%= currentPath.startsWith('/resourceOffers') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-box-seam-fill text-success"></i>
                <span>Resources</span>
            </div>
            <span class="sidebar-count"><%= sidebarCounts.resourceOffers %></span>
        </a>

        <a href="/verification" class="sidebar-link <%= currentPath.startsWith('/verification') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-patch-check-fill text-info"></i>
                <span>Verify Incidents</span>
            </div>
            <span class="sidebar-count"><%= sidebarCounts.verification %></span>
        </a>

        <a href="/fixit" class="sidebar-link <%= currentPath.startsWith('/fixit') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-tools text-primary"></i>
                <span>FixIt SG</span>
            </div>
            <span class="sidebar-count"><%= sidebarCounts.fixit || 0 %></span>
        </a>

    </div>

    <% if (currentUser && currentUser.role && currentUser.role.toLowerCase() === 'admin') { %>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">

        <div class="sidebar-title">
            ADMIN
        </div>

        <a href="/admin" class="sidebar-link <%= currentPath === '/admin' ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-speedometer2 text-primary"></i>
                <span>Dashboard</span>
            </div>
        </a>

        <a href="/admin/users" class="sidebar-link <%= currentPath.startsWith('/admin/users') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-people-fill text-info"></i>
                <span>Manage Users</span>
            </div>
        </a>

        <a href="/admin/reports" class="sidebar-link <%= currentPath.startsWith('/admin/reports') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-journal-text text-warning"></i>
                <span>Manage Reports</span>
            </div>
        </a>

        <a href="/admin/categories" class="sidebar-link <%= currentPath.startsWith('/admin/categories') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-tags-fill text-success"></i>
                <span>Manage Categories</span>
            </div>
        </a>

        <a href="/admin/incidents" class="sidebar-link <%= currentPath.startsWith('/admin/incidents') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                <span>Incident Status</span>
            </div>
        </a>

        <a href="/admin/moderation" class="sidebar-link <%= currentPath.startsWith('/admin/moderation') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-shield-check text-info"></i>
                <span>Moderate Reports</span>
            </div>
        </a>

        <a href="/admin/statistics" class="sidebar-link <%= currentPath.startsWith('/admin/statistics') ? 'active' : '' %>">
            <div class="sidebar-left">
                <i class="bi bi-graph-up-arrow text-primary"></i>
                <span>Statistics</span>
            </div>
        </a>

    </div>


    <% const counts = typeof sidebarCounts !== 'undefined' ? sidebarCounts : { allReports: 0, incidents: 0, helpRequests: 0, resourceOffers: 0, verification: 0 }; %>
    <span class="sidebar-count"><%= counts.allReports %></span>
    <span class="sidebar-count"><%= counts.incidents %></span>
    <span class="sidebar-count"><%= counts.helpRequests %></span>
    <span class="sidebar-count"><%= counts.resourceOffers %></span>
    <span class="sidebar-count"><%= counts.verification %></span>

</aside>
    <% } %>
</aside>
