<!-- Live Ticker -->

<div class="live-ticker">

    <span class="live-label">

        <span class="live-dot"></span>

        LIVE

    </span>

    <marquee scrollamount="5" id="liveTicker">

        Loading latest incidents...

    </marquee>

</div>


<script>

    async function loadLiveIncidents() {

        const ticker = document.getElementById('liveTicker');

        try {

            const response = await fetch('/api/live-incidents');

            if (!response.ok) {

                throw new Error(`HTTP error: ${response.status}`);

            }

            const incidents = await response.json();


            if (!incidents || incidents.length === 0) {

                ticker.textContent = 'No recent incidents reported.';

                return;

            }


            ticker.innerHTML = incidents

                .map(incident => `

                    <span style="cursor: pointer;"
                          onclick="window.location.href='/incidents/${incident.id}'">

                        ${incident.title} near ${incident.location}
                        (${incident.status})

                    </span>

                `)

                .join(' &nbsp; • &nbsp; ');


        } catch (error) {

            console.error('Unable to load live incidents:', error);

            ticker.textContent = 'Unable to load latest incidents.';

        }

    }


    // Load incidents immediately
    loadLiveIncidents();


    // Refresh every 30 seconds
    setInterval(loadLiveIncidents, 30000);

</script>