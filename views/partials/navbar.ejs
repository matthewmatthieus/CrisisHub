<nav class="navbar navbar-expand-lg top-navbar">

    <div class="container-fluid">

        <!-- Logo -->
        <a class="navbar-brand d-flex align-items-center" href="/">

            <div class="logo-icon">
                <i class="bi bi-shield-fill-check"></i>
            </div>

            <div class="ms-2">

                <div class="logo-title">
                    <span class="text-white">Crisis</span><span class="text-danger">Hub</span>
                </div>

                <small class="logo-subtitle">
                    Community Incident Reporting
                </small>

            </div>

        </a>

        <!-- Mobile Toggle -->
        <button class="navbar-toggler border-0 shadow-none"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarContent">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse" id="navbarContent">

            <!-- Navigation -->
            <ul class="navbar-nav ms-5">

                <li class="nav-item">
                    <a class="nav-link active" href="/">
                        <i class="bi bi-rss-fill me-1"></i>
                        Feed
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/incidents">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                        Incidents
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/resourceOffers">
                        <i class="bi bi-box-seam me-1"></i>
                        Resources
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/helpRequests">
                        <i class="bi bi-life-preserver me-1"></i>
                        Help
                    </a>
                </li>

            </ul>

            <!-- Right Side -->
