<div class="container-fluid py-4">

    <!-- Header -->
    <div class="dashboard-page-header d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                Welcome,
                <%= user ? user.username : currentUser.username %>
            </h2>

            <p class="text-secondary mb-0">
                Monitor incidents, verify reports and coordinate community response.
            </p>
        </div>

        <div class="dashboard-header-actions">

            <button class="btn dashboard-map-button px-4"
                    id="dashboardMapToggle"
                    type="button"
                    aria-pressed="false"
                    aria-controls="dashboardMapPanel">

                <i class="bi bi-map me-2"></i>
                <span>Map</span>

            </button>

            <div class="dropdown">

                <button
                    class="btn btn-warning report-main-btn dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown">

                    <i class="bi bi-plus-circle me-1"></i>
                    Report

                </button>

                <ul class="dropdown-menu">

                    <li>
                        <a class="dropdown-item" href="/incidents/create">

                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Report Incident

                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item" href="/fixit/create">

                            <i class="bi bi-tools me-2"></i>
                            Report FixIt

                        </a>
                    </li>

                </ul>

            </div>

        </div>

    </div>

    <!-- Statistics -->

    <div class="row g-3 mb-4">

        <div class="col-lg-3">

            <div class="stats-card">

                <small>ACTIVE INCIDENTS</small>

                <h2><%= stats.activeIncidents %></h2>

                <span class="text-warning">
                    Currently Active
                </span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>CRITICAL</small>

                <h2 class="text-danger">
                    <%= stats.criticalIncidents %>
                </h2>

                <span>
                    Immediate Response
                </span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>PENDING VERIFICATION</small>

                <h2 class="text-warning">
                    <%= stats.pendingVerification %>
                </h2>

                <span>
                    Awaiting Review
                </span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>RESOLVED</small>

                <h2 class="text-success">
                    <%= stats.resolvedIncidents %>
                </h2>

                <span>
                    Successfully Closed
                </span>

            </div>

        </div>

    </div>

    <!-- Reports and map switcher -->

    <div class="dashboard-view-stage" id="dashboardViewStage">

        <section class="dashboard-reports-panel is-visible"
         id="dashboardReportsPanel"
         aria-hidden="false">

        <% if (incidents.length === 0) { %>

            <div class="alert alert-info">

                No incidents have been reported yet.

            </div>

        <% } %>

        <% incidents.forEach(incident => { %>

        <div class="incident-card">

        <div class="d-flex justify-content-between">

            <div>

                <div class="d-flex align-items-center gap-2 mb-2">

                    <span class="badge
                        <% if (incident.severity === 'Critical') { %>
                            bg-danger
                        <% } else if (incident.severity === 'High') { %>
                            bg-warning text-dark
                        <% } else if (incident.severity === 'Medium') { %>
                            bg-primary
                        <% } else { %>
                            bg-success
                        <% } %>">

                        <%= incident.severity %>

                    </span>

                    <span class="badge
                        <% if (incident.displayStatus === 'Resolved') { %>
                            bg-success
                        <% } else if (incident.displayStatus === 'Verified') { %>
                            bg-primary
                        <% } else { %>
                            bg-secondary
                        <% } %>">

                        <%= incident.displayStatus %>

                    </span>

                </div>

                <h4>

                    <%= incident.title %>

                </h4>

                <p class="text-secondary mb-2">

                    <%= incident.description || "No description provided." %>

                </p>

                <small class="text-muted">

                    <i class="bi bi-geo-alt"></i>
                    <%= incident.location %>

                </small>

            </div>

            <div class="text-end">

                <small class="text-secondary">

                    Reported by

                </small>

                <br>

                <strong>

                    <%= incident.owner_name || "Unknown User" %>

                </strong>

                <br>

                <small class="text-muted">

                    <%= new Date(incident.created_at).toLocaleString() %>

                </small>

            </div>

        </div>

        <div class="mt-3">

            <small>Community Confidence</small>

            <div class="progress mt-2">

                <div
                    class="progress-bar bg-primary"
                    style="width:<%= incident.confidence %>%">

                </div>

            </div>

            <div class="d-flex justify-content-between mt-2">

                <small>

                    <%= incident.confidence %>% confidence

                </small>

                <small>
                    <%= incident.confirmCount %> confirmed

                    <% if (incident.disputeCount > 0) { %>
                        • <%= incident.disputeCount %> disputed
                    <% } %>
                </small>

            </div>

        </div>

        <div class="mt-4 d-flex gap-2 flex-wrap">

            <form action="/verification/<%= incident.id %>/confirm"
                method="POST"
                class="d-inline">

                <button
                    type="submit"
                    class="btn btn-success">

                    👍 Confirm

                </button>

            </form>

            <form action="/verification/<%= incident.id %>/dispute"
                method="POST"
                class="d-inline">

                <button
                    type="submit"
                    class="btn btn-outline-warning">

                    👎 Dispute

                </button>

            </form>

            <a href="/incidents/<%= incident.id %>"
            class="btn btn-outline-light">

                Details

            </a>

        </div>

        </div>

        <% }) %>

        <hr class="my-5">

        <h3 class="fw-bold mb-4">
            🔧 Community FixIt
        </h3>

        <div class="row">

        <% if (fixits.length === 0) { %>

            <div class="alert alert-info">
                No community FixIt reports yet.
            </div>

        <% } %>

        <% fixits.forEach(fix => { %>

        <div class="col-lg-6">

            <div class="card shadow-sm border-0 mb-4">

                <div class="card-body">

                    <h5 class="fw-bold"><%= fix.title %></h5>

                    <p class="text-muted">
                        <%= fix.description %>
                    </p>

                    <p>
                        <i class="bi bi-geo-alt"></i>
                        <%= fix.location %>
                    </p>

                    <div class="d-flex justify-content-between align-items-center">

                        <small>
                            Reported by
                            <strong><%= fix.owner_name %></strong>
                        </small>

                        <span class="badge bg-warning text-dark">
                            👍 <%= fix.supportCount %> Supports
                        </span>

                    </div>

                    <div class="mt-3">

                        <a href="/fixit/<%= fix.id %>"
                        class="btn btn-warning">

                            View FixIt

                        </a>

                    </div>

                </div>

            </div>

        </div>

        <% }) %>

        </div>

        </section>

        <section class="dashboard-map-panel"
                 id="dashboardMapPanel"
                 aria-hidden="true"
                 inert>

            <div class="dashboard-map-card">

                <div class="dashboard-map-header">

                    <div>
                        <h3 class="mb-1">Singapore Response Map</h3>
                        <p class="mb-0">View active reports, requests and available resources by location.</p>
                    </div>

                    <div class="map-filter-group" aria-label="Map marker filters">

                        <button class="map-filter is-active"
                                type="button"
                                data-map-type="incident"
                                aria-pressed="true">
                            <span class="map-filter-dot map-filter-dot-incident"></span>
                            Incidents
                        </button>

                        <button class="map-filter is-active"
                                type="button"
                                data-map-type="help-request"
                                aria-pressed="true">
                            <span class="map-filter-dot map-filter-dot-help"></span>
                            Help Requests
                        </button>

                        <button class="map-filter is-active"
                                type="button"
                                data-map-type="resource"
                                aria-pressed="true">
                            <span class="map-filter-dot map-filter-dot-resource"></span>
                            Resources
                        </button>

                        <button class="map-reset-button"
                                type="button"
                                id="dashboardMapReset">
                            <i class="bi bi-arrow-clockwise"></i>
                            Reset View
                        </button>

                    </div>

                </div>

                <div class="dashboard-map-shell">
                    <div id="dashboardMap"
                         role="region"
                         aria-label="Map of CrisisHub reports across Singapore"></div>
                    <div class="dashboard-map-message" id="dashboardMapMessage" hidden></div>
                </div>

            </div>

        </section>

    </div>

</div>
