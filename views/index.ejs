<div class="container-fluid py-4">

    <!-- Header -->
    <div class="dashboard-page-header d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold mb-1">Emergency Operations Dashboard</h2>

            <p class="text-secondary mb-0">
                Monitor incidents, verify reports and coordinate community response.
            </p>

        </div>

        <div class="dashboard-header-actions">

            <button class="btn dashboard-map-button px-4"
                    id="dashboardMapToggle"
                    type="button"
                    aria-pressed="false"
                    aria-controls="dashboardMapPanel">

                <i class="bi bi-map me-2"></i>

                <span>Map</span>

            </button>

            <div class="dropdown">

                <button class="btn btn-warning report-main-btn dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="false">

                    <i class="bi bi-plus-circle me-1"></i>
                    Report

                </button>


                <ul class="dropdown-menu">

                    <li>
                        <a class="dropdown-item" href="/incidents/create">

                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Report Incident

                        </a>
                    </li>


                    <li>
                        <a class="dropdown-item" href="/report/fixit">

                            <i class="bi bi-tools me-2"></i>
                            Report FixIt

                        </a>
                    </li>

                </ul>

            </div>

        </div>

    </div>

    <!-- Statistics -->

    <div class="row g-3 mb-4">

        <div class="col-lg-3">

            <div class="stats-card">

                <small>ACTIVE INCIDENTS</small>

                <h2>12</h2>

                <span class="text-warning">
                    +2 today
                </span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>CRITICAL</small>

                <h2 class="text-danger">3</h2>

                <span>Immediate response</span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>VERIFYING</small>

                <h2 class="text-warning">5</h2>

                <span>Community review</span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>RESOLVED</small>

                <h2 class="text-success">27</h2>

                <span>Completed today</span>

            </div>

        </div>

    </div>

    <!-- Reports and map switcher -->

    <div class="dashboard-view-stage" id="dashboardViewStage">

        <section class="dashboard-reports-panel is-visible"
                 id="dashboardReportsPanel"
                 aria-hidden="false">

            <div class="incident-card">

        <div class="d-flex justify-content-between">

            <div>

                <div class="d-flex align-items-center gap-2 mb-2">

                    <span class="badge bg-danger">
                        HIGH
                    </span>

                    <span class="badge bg-success">
                        VERIFIED
                    </span>

                </div>

                <h4>🌳 Fallen Tree Blocking Road</h4>

                <p class="text-secondary">

                    Large tree has fallen across the road near NTU South Spine.
                    Vehicles are unable to pass safely.

                </p>

            </div>

            <div class="text-end">

                <small class="text-secondary">
                    Reported by
                </small>

                <br>

                <strong>Community User</strong>

            </div>

        </div>

        <div class="mt-3">

            <small>Community Confidence</small>

            <div class="progress mt-2">

                <div class="progress-bar bg-primary"
                     style="width:82%">

                </div>

            </div>

            <div class="d-flex justify-content-between mt-2">

                <small>82% confidence</small>

                <small>18 confirmations</small>

            </div>

        </div>

        <div class="mt-4 d-flex gap-2">

            <button class="btn btn-success">

                👍 Confirm

            </button>

            <button class="btn btn-outline-warning">

                👎 Dispute

            </button>

            <button class="btn btn-outline-light">

                Details

            </button>

        </div>

            </div>

        </section>

        <section class="dashboard-map-panel"
                 id="dashboardMapPanel"
                 aria-hidden="true"
                 inert>

            <div class="dashboard-map-card">

                <div class="dashboard-map-header">

                    <div>
                        <h3 class="mb-1">Singapore Response Map</h3>
                        <p class="mb-0">View active reports, requests and available resources by location.</p>
                    </div>

                    <div class="map-filter-group" aria-label="Map marker filters">

                        <button class="map-filter is-active"
                                type="button"
                                data-map-type="incident"
                                aria-pressed="true">
                            <span class="map-filter-dot map-filter-dot-incident"></span>
                            Incidents
                        </button>

                        <button class="map-filter is-active"
                                type="button"
                                data-map-type="help-request"
                                aria-pressed="true">
                            <span class="map-filter-dot map-filter-dot-help"></span>
                            Help Requests
                        </button>

                        <button class="map-filter is-active"
                                type="button"
                                data-map-type="resource"
                                aria-pressed="true">
                            <span class="map-filter-dot map-filter-dot-resource"></span>
                            Resources
                        </button>

                        <button class="map-reset-button"
                                type="button"
                                id="dashboardMapReset">
                            <i class="bi bi-arrow-clockwise"></i>
                            Reset View
                        </button>

                    </div>

                </div>

                <div class="dashboard-map-shell">
                    <div id="dashboardMap"
                         role="region"
                         aria-label="Map of CrisisHub reports across Singapore"></div>
                    <div class="dashboard-map-message" id="dashboardMapMessage" hidden></div>
                </div>

            </div>

        </section>

    </div>

</div>
