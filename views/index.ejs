<% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
<% } %>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="container-fluid py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold mb-1">Emergency Operations Dashboard</h2>

            <p class="text-secondary mb-0">
                Monitor incidents, verify reports and coordinate community response.
            </p>

        </div>

        <button class="btn btn-primary px-4">

            <i class="bi bi-plus-circle me-2"></i>

            Report Incident

        </button>

    </div>

    <!-- Statistics -->

    <div class="row g-3 mb-4">

        <div class="col-lg-3">

            <div class="stats-card">

                <small>ACTIVE INCIDENTS</small>

                <h2>12</h2>

                <span class="text-warning">
                    +2 today
                </span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>CRITICAL</small>

                <h2 class="text-danger">3</h2>

                <span>Immediate response</span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>VERIFYING</small>

                <h2 class="text-warning">5</h2>

                <span>Community review</span>

            </div>

        </div>

        <div class="col-lg-3">

            <div class="stats-card">

                <small>RESOLVED</small>

                <h2 class="text-success">27</h2>

                <span>Completed today</span>

            </div>

        </div>

    </div>

    <!-- Incident Feed -->

    <div class="incident-card">

        <div class="d-flex justify-content-between">

            <div>

                <div class="d-flex align-items-center gap-2 mb-2">

                    <span class="badge bg-danger">
                        HIGH
                    </span>

                    <span class="badge bg-success">
                        VERIFIED
                    </span>

                </div>

                <h4>🌳 Fallen Tree Blocking Road</h4>

                <p class="text-secondary">

                    Large tree has fallen across the road near NTU South Spine.
                    Vehicles are unable to pass safely.

                </p>

            </div>

            <div class="text-end">

                <small class="text-secondary">
                    Reported by
                </small>

                <br>

                <strong>Community User</strong>

            </div>

        </div>

        <div class="mt-3">

            <small>Community Confidence</small>

            <div class="progress mt-2">

                <div class="progress-bar bg-primary"
                     style="width:82%">

                </div>

            </div>

            <div class="d-flex justify-content-between mt-2">

                <small>82% confidence</small>

                <small>18 confirmations</small>

            </div>

        </div>

        <div class="mt-4 d-flex gap-2">

            <button class="btn btn-success">

                👍 Confirm

            </button>

            <button class="btn btn-outline-warning">

                👎 Dispute

            </button>

            <button class="btn btn-outline-light">

                Details

            </button>

        </div>

    </div>

</div>
