<div class="page-header">
    <div>
        <h1><%= pageTitle %></h1>
        <p>Create or update a help request from the community.</p>
    </div>
</div>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="content-card form-card">
    <form action="<%= formAction %>" method="POST">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label" for="title">Title</label>
                <input class="form-control" id="title" name="title" type="text"
                       value="<%= request ? request.title : '' %>" required>
            </div>

            <div class="col-md-6">
                <label class="form-label" for="category">Category</label>
                <select class="form-select" id="category" name="category" required>
                    <% ['Water', 'Food', 'Medical', 'Shelter', 'Transport', 'Other'].forEach((category) => { %>
                        <option value="<%= category %>" <%= request && request.category === category ? 'selected' : '' %>>
                            <%= category %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label" for="quantity_needed">Quantity Needed</label>
                <input class="form-control" id="quantity_needed" name="quantity_needed" type="number" min="1"
                       value="<%= request ? request.quantity_needed : '' %>" required>
            </div>

            <div class="col-md-4">
                <label class="form-label" for="location">Location</label>
                <input class="form-control" id="location" name="location" type="text"
                       value="<%= request ? request.location : '' %>" required>
            </div>

            <div class="col-md-4">
                <label class="form-label" for="urgency">Urgency</label>
                <select class="form-select" id="urgency" name="urgency" required>
                    <% ['Low', 'Medium', 'High', 'Critical'].forEach((urgency) => { %>
                        <option value="<%= urgency %>" <%= request && request.urgency === urgency ? 'selected' : '' %>>
                            <%= urgency %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label" for="status">Status</label>
                <select class="form-select" id="status" name="status" required>
                    <% ['Open', 'Matched', 'Fulfilled', 'Closed'].forEach((status) => { %>
                        <option value="<%= status %>" <%= request && request.status === status ? 'selected' : '' %>>
                            <%= status %>
                        </option>
                    <% }) %>
                </select>
            </div>
        </div>

        <div class="form-actions mt-4">
            <a class="btn btn-outline-light" href="/helpRequests">Cancel</a>
            <button class="btn btn-primary" type="submit">
                <i class="bi bi-check-circle me-1"></i>
                Save Request
            </button>
        </div>
    </form>
</div>
