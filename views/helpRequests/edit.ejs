<div class="d-flex">

    <main class="flex-grow-1 p-4" style="min-height: 100vh;">
        <div class="container-fluid" style="max-width: 800px;">
            <div class="mb-4">
                <h1 class="h2 text-white fw-bold mb-1">Edit Help Request #<%= request.id %></h1>
                <p class="text-muted mb-0">Update information for this help request.</p>
            </div>

            <div class="card bg-dark text-white border-secondary shadow rounded-3">
                <div class="card-body p-4">
                    <form action="/helpRequests/<%= request.id %>?_method=PUT" method="POST">
                        <div class="mb-3">
                            <label class="form-label text-light fw-semibold">Title</label>
                            <input type="text" name="title" class="form-control bg-dark text-white border-secondary" value="<%= request.title %>" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light fw-semibold">Category</label>
                                <select name="category" class="form-select bg-dark text-white border-secondary" required>
                                    <option value="Water" <%= request.category === 'Water' ? 'selected' : '' %>>Water</option>
                                    <option value="Food" <%= request.category === 'Food' ? 'selected' : '' %>>Food</option>
                                    <option value="Medical" <%= request.category === 'Medical' ? 'selected' : '' %>>Medical</option>
                                    <option value="Shelter" <%= request.category === 'Shelter' ? 'selected' : '' %>>Shelter</option>
                                    <option value="Other" <%= request.category === 'Other' ? 'selected' : '' %>>Other</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light fw-semibold">Quantity Needed</label>
                                <input type="number" name="quantity_needed" class="form-control bg-dark text-white border-secondary" value="<%= request.quantity_needed %>" min="1" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-light fw-semibold">Location</label>
                            <input type="text" name="location" class="form-control bg-dark text-white border-secondary" value="<%= request.location %>" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light fw-semibold">Urgency</label>
                                <select name="urgency" class="form-select bg-dark text-white border-secondary">
                                    <option value="Low" <%= request.urgency === 'Low' ? 'selected' : '' %>>Low</option>
                                    <option value="Medium" <%= request.urgency === 'Medium' ? 'selected' : '' %>>Medium</option>
                                    <option value="High" <%= request.urgency === 'High' ? 'selected' : '' %>>High</option>
                                    <option value="Critical" <%= request.urgency === 'Critical' ? 'selected' : '' %>>Critical</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-light fw-semibold">Status</label>
                                <select name="status" class="form-select bg-dark text-white border-secondary">
                                    <option value="Open" <%= request.status === 'Open' ? 'selected' : '' %>>Open</option>
                                    <option value="In Progress" <%= request.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                                    <option value="Resolved" <%= request.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-secondary">
                            <a href="/helpRequests/<%= request.id %>" class="btn btn-outline-light">Cancel</a>
                            <button type="submit" class="btn btn-warning px-4">Update Request</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>
