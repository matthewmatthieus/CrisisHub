<div class="page-header">
    <div>
        <h1>Help Requests</h1>
        <p>Review and manage community requests for urgent assistance.</p>
    </div>

    <% if (isAdmin) { %>
        <div class="page-actions">
            <a class="btn btn-primary" href="/helpRequests/new">
                <i class="bi bi-plus-circle me-1"></i>
                New Request
            </a>
        </div>
    <% } %>
</div>

<% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
<% } %>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="content-card">
    <div class="card-header">
        <h2>
            <i class="bi bi-life-preserver"></i>
            Open Help Requests
        </h2>
        <span class="text-secondary"><%= requests.length %> requests</span>
    </div>

    <% if (requests.length === 0) { %>
        <p class="empty-state">No help requests have been submitted yet.</p>
    <% } else { %>
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Urgency</th>
                        <th>Quantity</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Requester</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% requests.forEach((request) => { %>
                        <tr>
                            <td><strong><%= request.title %></strong></td>
                            <td><%= request.category %></td>
                            <td><%= request.urgency %></td>
                            <td><%= request.quantity_needed %></td>
                            <td><%= request.location %></td>
                            <td><span class="status-pill"><%= request.status %></span></td>
                            <td><%= request.requester || 'Unknown' %></td>
                            <td class="text-end">
                                <a class="btn btn-outline-light btn-sm" href="/helpRequests/<%= request.id %>">
                                    Details
                                </a>
                                <% if (isAdmin) { %>
                                    <a class="btn btn-outline-light btn-sm" href="/helpRequests/<%= request.id %>/edit">
                                        Edit
                                    </a>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
