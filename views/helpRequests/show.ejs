<div class="d-flex">

    <main class="flex-grow-1 p-4" style="min-height: 100vh;">
        <div class="container-fluid" style="max-width: 900px;">
            <!-- Header Nav -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <a href="/helpRequests" class="text-decoration-none text-muted small mb-2 d-inline-block">
                        <i class="bi bi-arrow-left me-1"></i> Back to Help Requests
                    </a>
                    <h1 class="h2 text-white fw-bold mb-0">Help Request #<%= request.id %></h1>
                </div>

                <div class="btn-group">
                    <a href="/helpRequests/<%= request.id %>/edit" class="btn btn-outline-warning">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                    <form action="/helpRequests/<%= request.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this request?');">
                        <button type="submit" class="btn btn-outline-danger ms-2">
                            <i class="bi bi-trash me-1"></i> Delete
                        </button>
                    </form>
                </div>
            </div>

            <!-- Details Card -->
            <div class="card bg-dark text-white border-secondary shadow rounded-3">
                <div class="card-header bg-dark border-secondary py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><%= request.title %></h5>
                    <% if (request.urgency === 'Critical') { %>
                        <span class="badge bg-danger px-3 py-2"><%= request.urgency %></span>
                    <% } else if (request.urgency === 'High') { %>
                        <span class="badge bg-warning text-dark px-3 py-2"><%= request.urgency %></span>
                    <% } else { %>
                        <span class="badge bg-secondary px-3 py-2"><%= request.urgency %></span>
                    <% } %>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Category</p>
                            <p class="fs-5 text-info mb-0"><i class="bi bi-tag me-2"></i><%= request.category %></p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Quantity Needed</p>
                            <p class="fs-5 text-white mb-0"><i class="bi bi-boxes me-2"></i><%= request.quantity_needed %></p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Location</p>
                            <p class="fs-5 text-white mb-0"><i class="bi bi-geo-alt me-2"></i><%= request.location %></p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Requested By</p>
                            <p class="fs-5 text-white mb-0"><i class="bi bi-person me-2"></i>User #<%= request.user_id %></p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1 small text-uppercase fw-semibold">Status</p>
                            <span class="badge bg-success fs-6"><%= request.status || 'Open' %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>