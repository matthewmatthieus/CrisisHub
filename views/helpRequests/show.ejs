<div class="page-header">
    <div>
        <h1><%= request.title %></h1>
        <p><%= request.quantity_needed %> needed for <%= request.category %> support.</p>
    </div>

    <% if (isAdmin) { %>
        <div class="page-actions">
            <a class="btn btn-outline-light" href="/helpRequests/<%= request.id %>/edit">
                <i class="bi bi-pencil-square me-1"></i>
                Edit
            </a>
            <form action="/helpRequests/<%= request.id %>/delete" method="POST">
                <button class="btn btn-danger" type="submit">
                    <i class="bi bi-trash me-1"></i>
                    Delete
                </button>
            </form>
        </div>
    <% } %>
</div>

<div class="dashboard-grid mb-4">
    <div class="stat-card">
        <p class="stat-label">Category</p>
        <div class="stat-number"><%= request.category %></div>
    </div>
    <div class="stat-card">
        <p class="stat-label">Urgency</p>
        <div class="stat-number"><%= request.urgency %></div>
    </div>
    <div class="stat-card">
        <p class="stat-label">Location</p>
        <div class="stat-number"><%= request.location %></div>
    </div>
    <div class="stat-card">
        <p class="stat-label">Status</p>
        <div class="stat-number"><%= request.status %></div>
    </div>
    <div class="stat-card">
        <p class="stat-label">Requester</p>
        <div class="stat-number"><%= request.requester || 'Unknown' %></div>
    </div>
</div>

<div class="content-card">
    <div class="card-header">
        <h2><i class="bi bi-card-text"></i> Notes</h2>
    </div>
    <p>Request created by admin management.</p>
</div>
