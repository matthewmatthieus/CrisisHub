<div class="page-header">
    <div>
        <h1><%= offer.item_name %></h1>
        <p><%= offer.quantity %> available in <%= offer.location %> for <%= offer.category %> requests.</p>
    </div>

    <% if (isOwner) { %>
        <div class="page-actions">
            <a class="btn btn-outline-light" href="/resourceOffers/<%= offer.id %>/edit">
                <i class="bi bi-pencil-square me-1"></i>
                Edit
            </a>
            <form action="/resourceOffers/<%= offer.id %>/delete" method="POST">
                <button class="btn btn-danger" type="submit">
                    <i class="bi bi-trash me-1"></i>
                    Delete
                </button>
            </form>
        </div>
    <% } %>
</div>

<% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
<% } %>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="dashboard-grid mb-4">
    <div class="stat-card">
        <p class="stat-label">Category</p>
        <div class="stat-number stat-text"><%= offer.category %></div>
    </div>

    <div class="stat-card">
        <p class="stat-label">Quantity</p>
        <div class="stat-number"><%= offer.quantity %></div>
    </div>

    <div class="stat-card">
        <p class="stat-label">Status</p>
        <div class="stat-number stat-text"><%= offer.status %></div>
    </div>

    <div class="stat-card">
        <p class="stat-label">Matches</p>
        <div class="stat-number"><%= matches.length %></div>
    </div>
</div>

<div class="content-card">
    <div class="card-header">
        <h2>
            <i class="bi bi-diagram-3"></i>
            Suggested Help Request Matches
        </h2>
        <span class="text-secondary">Score uses category, quantity, location, and urgency.</span>
    </div>

    <% if (matches.length === 0) { %>
        <p class="empty-state">No suitable help requests found for this offer yet.</p>
    <% } else { %>
        <div class="match-list">
            <% matches.forEach((match) => { %>
                <div class="match-card">
                    <div>
                        <div class="match-topline">
                            <span class="status-pill"><%= match.status %></span>
                            <span class="text-secondary"><%= match.match_score %>% suitability</span>
                        </div>
                        <h3><%= match.title %></h3>
                        <p>
                            Needs <strong><%= match.quantity_needed %></strong> item(s) for
                            <strong><%= match.category %></strong> in <strong><%= match.location %></strong>.
                            Urgency: <strong><%= match.urgency %></strong>.
                        </p>
                        <% if (match.fulfillment_status) { %>
                            <p class="small text-secondary">
                                Fulfillment: <%= match.fulfillment_status %>,
                                quantity <%= match.fulfilled_quantity %>
                            </p>
                        <% } %>
                    </div>

                    <% if (isOwner && match.status === 'Pending') { %>
                        <div class="match-actions">
                            <form action="/matches/<%= match.id %>/accept" method="POST">
                                <button class="btn btn-success btn-sm" type="submit">Accept</button>
                            </form>
                            <form action="/matches/<%= match.id %>/reject" method="POST">
                                <button class="btn btn-outline-warning btn-sm" type="submit">Reject</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>
