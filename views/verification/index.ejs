<div class="page-header">

    <div>
        <h1>Incident Verification</h1>
        <p>Community verification and priority assessment.</p>
    </div>

</div>

<div class="row g-4">

    <% incidents.forEach(incident => { %>

        <div class="col-lg-6">

            <div class="incident-card">

                <div class="incident-header">

                    <div>

                        <h3><%= incident.title %></h3>

                        <p>Severity: <strong><%= incident.severity %></strong></p>

                    </div>

                    <span class="badge badge-verifying">
                        <%= incident.priorityLevel %>
                    </span>

                </div>

                <div class="incident-details">

                    <p>
                        Confirm:
                        <strong><%= incident.confirmCount %></strong>
                    </p>

                    <p>
                        Dispute:
                        <strong><%= incident.disputeCount %></strong>
                    </p>

                    <p>
                        Confidence:
                        <strong><%= incident.confidence %>%</strong>
                    </p>

                    <div class="confidence-bar">
                        <div
                            class="confidence-fill"
                            style="width:<%= incident.confidence %>%">
                        </div>
                    </div>

                    <p class="mt-3">
                        Priority Score:
                        <strong><%= incident.priorityScore %></strong>
                    </p>

                </div>

                <div class="d-flex gap-2 mt-3">

                    <button class="btn btn-success">
                        Confirm
                    </button>

                    <button class="btn btn-danger">
                        Dispute
                    </button>

                </div>

            </div>

        </div>

    <% }) %>

</div>